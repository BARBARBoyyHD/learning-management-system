// Database Schema for Quizizz Clone (Lite to Advanced)
// Dirancang untuk mendukung: MCQ, Match, Reorder, Categorize, Hotspot, dll.

Table users {
  id integer [primary key, increment]
  username varchar [not null]
  email varchar [unique, not null]
  password varchar [not null]
  role varchar // 'teacher', 'student'
  created_at timestamp [default: now()]
}

Table quizzes {
  id integer [primary key, increment]
  teacher_id integer [ref: > users.id]
  title varchar [not null]
  description text
  is_public boolean [default: true]
  created_at timestamp [default: now()]
}

Table questions {
  id integer [primary key, increment]
  quiz_id integer [ref: > quizzes.id]

  // Jenis Soal: 'multiple_choice', 'match', 'reorder', 'drag_drop', 'hotspot'
  question_type varchar [not null] 

  question_text text [not null]
  media_url varchar // URL untuk Gambar/Audio/Video (Visual Learning)

  // Metadata untuk setting tambahan (misal: koordinat hotspot, durasi timer)
  settings json 

  points integer [default: 10]
  order_index integer // Urutan soal dalam satu kuis
}

Table question_options {
  id integer [primary key, increment]
  question_id integer [ref: > questions.id]

  // Kolom serbaguna untuk teks pilihan atau kunci jawaban
  option text 


  // Untuk 'Reorder' atau urutan pilihan
  sort_order integer 

  is_correct boolean [default: false]


}

Table student_responses {
  id integer [primary key, increment]
  user_id integer [ref: > users.id]
  quiz_id integer [ref: > quizzes.id]
  score integer
  completed_at timestamp [default: now()]
}

Table response_details {
  id integer [primary key, increment]
  response_id integer [ref: > student_responses.id]
  question_id integer [ref: > questions.id]

  // Menyimpan apa yang dijawab siswa (bisa teks atau ID option)
  answer_given text 
  is_correct boolean
}
