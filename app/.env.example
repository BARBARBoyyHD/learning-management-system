# =============================================================================
# Quizizz Clone (Lite Version) - Environment Variables Example
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in the required values (marked with *)
# 3. NEVER commit .env to version control
# 4. Keep this file (.env.example) committed as a reference
#
# 🚀 DEPLOYMENT TO VERCEL:
# For production deployment on Vercel, configure these variables in:
# Vercel Dashboard → Settings → Environment Variables
# See: /docs/VERCEL_DEPLOYMENT.md for complete setup guide
# =============================================================================

# =============================================================================
# REQUIRED VARIABLES (*)
# These must be configured for the application to work
# =============================================================================

# -----------------------------------------------------------------------------
# * Supabase Authentication (REQUIRED)
# Get these from: https://app.supabase.com/project/_/settings/api
# -----------------------------------------------------------------------------
# Step 1: Create a Supabase project at https://supabase.com
# Step 2: Go to Project Settings > API
# Step 3: Copy the URL and anon/public key below

NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here"

# -----------------------------------------------------------------------------
# * Application URL (REQUIRED)
# The URL where your app is running
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Site URL for metadata (OG tags, SEO, sitemaps)
# Vercel will auto-set this to your deployment URL in production
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# For production, change to your actual domain:
# NEXT_PUBLIC_APP_URL="https://quizizz.yourdomain.com"
# NEXT_PUBLIC_SITE_URL="https://quizizz.yourdomain.com"

# -----------------------------------------------------------------------------
# * Database Connection (REQUIRED for Prisma ORM)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# -----------------------------------------------------------------------------
# For local development with PostgreSQL:
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/quizizz_clone"

# For Supabase Database (if using Supabase's PostgreSQL):
# Get connection string from: Supabase Dashboard > Settings > Database
# DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# =============================================================================
# OPTIONAL VARIABLES
# These can be left as defaults or configured as needed
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME="Quizizz Clone"
NODE_ENV="development"

# Enable debug mode for development
NEXT_PUBLIC_DEBUG="true"

# -----------------------------------------------------------------------------
# Supabase Service Role Key (SERVER-SIDE ONLY - NEVER EXPOSE)
# Get from: Supabase Dashboard > Settings > API > Service Role Key
# -----------------------------------------------------------------------------
# ⚠️ WARNING: This key bypasses RLS policies! Only use in server-side code.
# ⚠️ Never put this in client-side code or expose it to the browser.

# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# -----------------------------------------------------------------------------
# Email Configuration (Supabase handles email delivery)
# Configure email sender in Supabase Dashboard > Authentication > Email Templates
# -----------------------------------------------------------------------------
# MAIL_FROM="noreply@quizizz.local"

# For custom SMTP (if not using Supabase Email):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"

# -----------------------------------------------------------------------------
# File Storage (Choose ONE option)
# -----------------------------------------------------------------------------

# Option 1: Vercel Blob Storage (Recommended for Vercel hosting)
# Get token from: Vercel Dashboard > Storage > Blob
# BLOB_READ_WRITE_TOKEN="vercel_blob_token_here"

# Option 2: AWS S3
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_BUCKET_NAME="quizizz-assets"
# AWS_REGION="us-east-1"

# -----------------------------------------------------------------------------
# OAuth Providers (Optional - for future Google/GitHub login)
# Configure in Supabase Dashboard > Authentication > Providers
# -----------------------------------------------------------------------------

# Google OAuth:
# NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth:
# NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# -----------------------------------------------------------------------------
# Mayar.id Payment Gateway (REQUIRED for Premium Subscription)
# Get API keys from: https://docs.mayar.id/api-reference/introduction
# -----------------------------------------------------------------------------
# Step 1: Create Mayar.id account and get API credentials
# Step 2: Create a product for Premium Subscription (Rp 49.000/month)
# Step 3: Copy API key, webhook secret, and product ID below
# Step 4: Set up webhook endpoint: https://yourdomain.com/api/v1/subscription/webhook
#
# For development/testing, use Sandbox environment (api.mayar.club)
# For production, use Production environment (api.mayar.id)

# Sandbox API Key (for development)
# Get from: https://web.mayar.club/api-keys
MAYAR_API_KEY="your_mayar_sandbox_api_key_here"

# Sandbox Product ID (for development)
# Create a test product at: https://web.mayar.club/products
MAYAR_PRODUCT_ID="your_mayar_sandbox_product_id_here"

# Webhook Secret (optional, for webhook signature verification)
# Get from: https://web.mayar.club/webhooks
MAYAR_WEBHOOK_SECRET="your_webhook_secret_here"

# For production, change to production credentials:
# MAYAR_API_KEY="your_mayar_production_api_key_here"
# MAYAR_PRODUCT_ID="your_mayar_production_product_id_here"
# Get production keys from: https://web.mayar.id/api-keys

# -----------------------------------------------------------------------------
# Security & Rate Limiting (Optional)
# -----------------------------------------------------------------------------

# reCAPTCHA v2 (for bot protection on forms)
# Get keys from: https://www.google.com/recaptcha/admin
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
# RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"

# Rate Limiting with Vercel KV (Redis)
# KV_REST_API_URL="redis://your-vercel-kv-url"
# KV_REST_API_TOKEN="your-vercel-kv-token"

# -----------------------------------------------------------------------------
# Monitoring & Analytics (Optional)
# -----------------------------------------------------------------------------

# Sentry (Error tracking)
# SENTRY_DSN="https://your-sentry-dsn"
# NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn"

# =============================================================================
# SETUP CHECKLIST
# =============================================================================
# 
# Before running the application:
# 
# [ ] 1. Create Supabase project at https://supabase.com
# [ ] 2. Enable Email authentication in Supabase Dashboard
# [ ] 3. Copy NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY
# [ ] 4. Set up local PostgreSQL OR use Supabase Database connection string
# [ ] 5. Copy DATABASE_URL from your database
# [ ] 6. Set NEXT_PUBLIC_APP_URL to your development URL
# [ ] 7. Run `npm run db:generate` to generate Prisma Client
# [ ] 8. Run `npm run db:migrate` to create database tables
# [ ] 9. Run `npm run dev` to start the application
# 
# =============================================================================
