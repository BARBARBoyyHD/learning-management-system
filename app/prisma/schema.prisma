// BrainBlitz - Prisma Schema
// Based on ERD Guideline (DOC-QCL-ERD-001) Section 3
// 6 core tables with UUID primary keys

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  active
  cancelled
  expired
  trial
}

// ============================================================================
// USER MODEL
// Stores teacher-specific data (Supabase auth.users is source of truth for auth)
// users.id matches Supabase auth.users.id (UUID)
// ============================================================================
model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(255)
  role      String   @default("teacher") @db.VarChar(20) // 'teacher' or 'student'
  createdAt DateTime @default(now())

  // Subscription fields for pricing tiers
  subscriptionTier     SubscriptionTier   @default(FREE)
  subscriptionStatus   SubscriptionStatus @default(trial)
  trialEndsAt          DateTime?
  subscriptionEndsAt   DateTime?
  mayarCustomerId      String?            @db.VarChar(255)

  // Relations
  quizzes   Quiz[]
  responses StudentResponse[]

  // Indexes for performance
  @@index([email])
  @@index([role])
  @@index([subscriptionTier])

  // Constraints
  @@map("users")
}

// ============================================================================
// QUIZ MODEL
// Stores quiz/assessment definitions within courses
// ============================================================================
model Quiz {
  id          String   @id @default(uuid())
  teacherId   String
  title       String   @db.VarChar(200)
  description String?  @db.Text
  timeLimit   Int?     // Time limit in minutes (null = no limit)
  isPublic    Boolean  @default(true)
  accessCode  String?  @unique @db.Char(6) // 6-character alphanumeric code for private quizzes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relations
  teacher   User              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questions Question[]
  responses StudentResponse[]

  // Indexes for performance
  @@index([teacherId])
  @@index([isPublic])
  @@index([accessCode])

  // Constraints
  @@map("quizzes")
}

// ============================================================================
// QUESTION MODEL
// Stores individual questions within quizzes
// Supports 5 question types with JSON-based settings
// ============================================================================
model Question {
  id           String     @id @default(uuid())
  quizId       String
  questionType String     @db.VarChar(30) // 'multiple_choice', 'essay', 'fill_blank', 'match', 'reorder'
  questionText String     @db.Text
  mediaUrl     String?    @db.Text
  settings     Json?      // Question-type-specific configuration
  points       Int        @default(10)
  orderIndex   Int

  // Relations
  quiz    Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  details ResponseDetail[]

  // Indexes for performance
  @@index([quizId])
  @@index([questionType])

  // Constraints
  @@map("questions")
}

// ============================================================================
// QUESTION OPTION MODEL
// Stores answer options for questions (Multiple Choice, Match, Reorder)
// ============================================================================
model QuestionOption {
  id         String  @id @default(uuid())
  questionId String
  option     String  @db.Text // Universal column for option text or answer key
  sortOrder  Int?    // For 'Reorder' or option ordering
  isCorrect  Boolean @default(false)

  // Relations
  question Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Index for performance
  @@index([questionId])

  // Constraints
  @@map("question_options")
}

// ============================================================================
// STUDENT RESPONSE MODEL
// Stores student quiz submissions
// ============================================================================
model StudentResponse {
  id          String   @id @default(uuid())
  userId      String
  quizId      String
  score       Int?
  completedAt DateTime @default(now())

  // Relations
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz     Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  details  ResponseDetail[]

  // Indexes for performance
  @@index([userId])
  @@index([quizId])

  // Constraints
  @@map("student_responses")
}

// ============================================================================
// RESPONSE DETAIL MODEL
// Stores individual question responses within a submission
// ============================================================================
model ResponseDetail {
  id          String   @id @default(uuid())
  responseId  String
  questionId  String
  answerGiven String?  @db.Text // Stores what student answered (text or option ID)
  isCorrect   Boolean?

  // Relations
  response StudentResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Indexes for performance
  @@index([responseId])
  @@index([questionId])

  // Constraints
  @@map("response_details")
}
